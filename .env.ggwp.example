# Copy to .env for ggwp production/staging
GAMEMODE=ggwp
HOST=0.0.0.0
PORT=43594

# ggwp.dk account database (same as OpenRune central — OsrsAuth.php)
GGWP_AUTH_ENABLED=1
GGWP_POSTGRES_JDBC_URL=jdbc:postgresql://your-db-host:5432/openrune_central
GGWP_POSTGRES_USER=your_db_user
GGWP_POSTGRES_PASSWORD=your_password_here

# Comma-separated extra admin names (plus modlevel.admin/owner from DB)
ADMIN_USERNAMES=your_admin_username
